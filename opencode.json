{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "lsp": "allow",

    "bash": {
      // By default allow all bash
      "*": "allow",
    
      // =============================
      // Git commands
      // =============================
      "git*": "ask",
      // 🚫 Always block remote interaction
      "git push*": "deny",
      "git pull*": "deny",
      "git fetch*": "deny",
      "git remote*": "deny",
      // ✅ Allow safe local commits
      "git commit*": "allow",
      "git add*": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      
      // =============================
      // Remote / network execution
      // =============================
      "curl * | bash": "deny",
      "wget * | sh": "deny",
      "ssh *": "deny",
      "scp *": "deny",
      "nc *": "deny",
      
      // =============================
      // 🚫 System destruction
      // =============================
      "rm -rf *": "deny",
      "rm -r /": "deny",
      "mkfs*": "deny",
      "dd*": "deny",
      "wipefs*": "deny",
      
      // =============================
      // 🚫 Privilege escalation
      // =============================
      "sudo *": "deny",
      "su *": "deny",
      "chmod 000 *": "deny",
      "chown root*": "deny",

      // =============================
      // 🚫 Process abuse
      // =============================
      "kill -9 *": "deny",
      "pkill *": "deny",
      "killall *": "deny",

      // =============================
      // 🚫 Environment corruption
      // =============================
      "export PATH=*": "deny",
      "unset PATH": "deny",
      "history -c": "deny",

      // =============================
      // 🚫 Hardware / OS control
      // =============================
      "shutdown*": "deny",
      "reboot*": "deny",
      "halt*": "deny",
      "poweroff*": "deny",

      // =============================
      // Others
      // =============================
      ":(){:|:&};:": "deny"
      
    },
    
    "edit": {
      ".git/**": "deny",
      ".env*": "deny",
      ".opencode*": "ask",
      "~/miniconda3/envs/env-aivocode/**": "deny"
    },
    "external_directory": {
      "~/miniconda3/envs/env-aivocode/**": "allow"
    }
  },

  "instructions": ["aivocode/RULES.md", "aivocode/SUBAGENT_WORKFLOW.md", "aivocode/TONE.md"],

  "provider": {
    "openrouter": {
      "models": {
        "z-ai/glm-5:nitro": {
          "name": "GLM-5 Nitro"
        }
      }
    }
  },


  // ----------------------------------------
  // openrouter/openai/gpt-5.2
  // openrouter/openai/gpt-5.2-codex
  // ----------------------------------------
  "agent": {
    "plan": {
      "mode": "primary",
      "model": "opencode/glm-5",
      "disable": true
    },
    "build": {
      "mode": "primary",
      "model": "opencode/glm-5",
      "disable": true
    },

    // Custom agents
    "web-ops": {
      "model": "opencode/minimax-m2.5"
    },
    "explore": {
      "model": "opencode/minimax-m2.5"
    },
    "architect": {
      "model": "opencode/glm-5"
    },
    "coder": {
      "model": "opencode/gpt-5.2-codex",
    },
  },
  "default_agent": "architect",
}
